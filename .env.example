# Copy to .env.local for local dev:  cp .env.example .env.local
# Then seed the test account:        npm run seed

# --- Collection backend (per-user sync) ---
# Required to register NEW users via the UI. The seeded "tester" account is
# inserted straight into the DB and bypasses this, so it's optional for testing.
INVITE_CODE=PANINI-TEST
SESSION_TTL_DAYS=90
# STICKER_DB_PATH=./data/stickers.db

# --- /api/scan vision provider (server-side only) ---
# Only needed to test the camera "scan stickers" feature; browse/swipe work
# without it. Set exactly one provider key.
# SCAN_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
